{
  "name": "base-saas",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build -w packages/shared && concurrently -n backend,frontend -c blue,green \"npm run start:dev -w backend\" \"npm run start -w frontend\"",
    "dev:backend": "npm run start:dev -w backend",
    "dev:frontend": "npm run start -w frontend",
    "build:shared": "npm run build -w packages/shared",
    "db:types": "npx supabase gen types --local > backend/src/database/types.ts"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
